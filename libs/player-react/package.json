{
  "name": "@waveform-audio/player",
  "type": "module",
  "version": "0.0.4",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./index.css": "./dist/index.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --workspace vitest.workspace.ts --project unit",
    "test:unit": "vitest run --workspace vitest.workspace.ts --project unit",
    "test:browser": "vitest run --workspace vitest.workspace.ts --browser=chromium",
    "test:browser:setup": "playwright install chromium",
    "test:watch": "vitest watch --workspace vitest.workspace.ts --project unit",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --project unit --coverage",
    "test:ui": "vitest --ui"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.473.0",
    "nanoid": "^5.1.7",
    "tailwind-merge": "^2.6.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@waveform-audio/inf": "workspace:*",
    "autoprefixer": "^10.4.27",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4",
    "vitest-browser-react": "^0.0.4",
    "webdriverio": "^9.27.0"
  }
